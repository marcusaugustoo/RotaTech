{
  "name": "RouteFeedback",
  "type": "object",
  "properties": {
    "driver_email": {
      "type": "string"
    },
    "route_date": {
      "type": "string",
      "format": "date"
    },
    "rating": {
      "type": "number",
      "description": "Avalia\u00e7\u00e3o de 1 a 5"
    },
    "comment": {
      "type": "string"
    },
    "fuel_saved": {
      "type": "number",
      "description": "Combust\u00edvel economizado em litros"
    },
    "time_saved": {
      "type": "number",
      "description": "Tempo economizado em minutos"
    },
    "distance_km": {
      "type": "number"
    }
  },
  "required": [
    "rating"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}